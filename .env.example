# Qcells Cloud API Configuration
# Copy this file to .env and fill in your actual values

# Qcells Cloud API Base URL
QCELLS_BASE_URL=https://qhome-ess-g3.q-cells.eu/proxyApp/proxy/api

# LAN Adapter Registration number (NOT the inverter Device SN!)
QCELLS_WIFI_SN=your_lan_adapter_registration_number_here

# API Key / Token ID from Qcells Cloud
QCELLS_API_KEY=your_api_key_here